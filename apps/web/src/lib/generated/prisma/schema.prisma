generator client {
  provider = "prisma-client-js"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TENANT
}

enum BillType {
  RENT
  ELECTRICITY
  WATER
  CUSTOM
}

enum PaymentMethod {
  MOMO
  AIRTEL
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
  EXPIRED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(TENANT)
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantProfile   Tenant?
  adminProperties Property[]

  announcements   Announcement[]   @relation("Announcements")
  contactMessages ContactMessage[] @relation("ContactMessages")
}

model Property {
  id        String   @id @default(cuid())
  name      String
  address   String?
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  units     Unit[]
  createdAt DateTime @default(now())
}

model Unit {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String // e.g., "Room A", "Apartment 1"
  tenants    Tenant[]
  bills      Bill[]
  createdAt  DateTime @default(now())
}

model Tenant {
  id                    String     @id @default(cuid())
  userId                String     @unique
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  unitId                String
  unit                  Unit       @relation(fields: [unitId], references: [id])
  rentAmount            Float
  startDate             DateTime
  isActive              Boolean    @default(true)
  nationalId            String?
  emergencyContactName  String?
  emergencyContactPhone String?
  numberOfOccupants     Int?
  occupants             Occupant[]
  contracts             Contract[]
  bills                 Bill[]
  createdAt             DateTime   @default(now())
}

model Bill {
  id        String        @id @default(cuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unitId    String
  unit      Unit          @relation(fields: [unitId], references: [id])
  type      BillType
  amount    Float
  period    String // format: YYYY-MM
  dueDate   DateTime
  paidAt    DateTime?
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())

  payment Payment?
}

model Payment {
  id            String        @id @default(cuid())
  billId        String        @unique
  bill          Bill          @relation(fields: [billId], references: [id], onDelete: Cascade)
  amount        Float
  method        PaymentMethod
  transactionId String? // external MoMo transaction ID
  status        PaymentStatus @default(PENDING)
  meta          Json? // store full response from provider
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdAt DateTime @default(now())
  authorId  String
  author    User     @relation("Announcements", fields: [authorId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  subject   String
  message   String
  tenantId  String
  tenant    User     @relation("ContactMessages", fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)
}

model Occupant {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  phone    String?
  relation String? // e.g., spouse, child, etc.
}

model Contract {
  id                String         @id @default(cuid())
  tenantId          String
  tenant            Tenant         @relation(fields: [tenantId], references: [id])
  startDate         DateTime
  endDate           DateTime
  monthlyRent       Float
  deposit           Float?
  utilities         Json // e.g., { electricity: "tenant", water: "landlord", internet: "tenant" }
  status            ContractStatus @default(PENDING_TENANT_SIGNATURE)
  content           String? // full filled agreement text
  tenantSignature   String?
  tenantSignedAt    DateTime?
  landlordSignature Boolean        @default(false)
  landlordSignedAt  DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

enum ContractStatus {
  PENDING_TENANT_SIGNATURE
  PENDING_LANDLORD_SIGNATURE
  ACTIVE
  EXPIRED
  TERMINATED
}

model ClearanceCertificate {
  id                    String   @id @default(cuid())
  tenantName            String
  nationalId            String?
  propertyAddress       String
  startDate             DateTime
  endDate               DateTime
  rentCleared           Boolean
  utilitiesCleared      Boolean
  serviceChargesCleared Boolean
  damagesCleared        Boolean
  propertyCondition     String // Good, Acceptable, Minor repairs required
  repairDetails         String?
  securityDeposit       Float?
  depositRefunded       Boolean?
  refundAmount          Float?
  depositRetainedReason String?
  landlordName          String
  landlordSignature     String
  landlordPhone         String
  tenantEmail           String?
  tenantPhone           String?
  content               String?
  createdAt             DateTime @default(now())
}
